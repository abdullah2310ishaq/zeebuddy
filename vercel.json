{
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install --include=dev",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/v1/cron/publish-scheduled",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "src/app/api/**/*.ts": {
      "includeFiles": "node_modules/.prisma/client/**"
    }
  }
}

